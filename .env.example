DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/banana_clockJWT_SECRET=your-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Set to false to skip retraining on startup and use the existing banana_clock_model.pth
RETRAIN=true

# Optional: force training device (mps, cuda, cpu). Auto-detected if not set.
# TORCH_DEVICE=cpu